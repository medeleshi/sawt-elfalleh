# ============================================================
# 🌾 Sawt ElFalleh — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase — required (public, safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL — used for OAuth callbacks and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── SECURITY WARNING ───────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY must NEVER be used in:
#   - client-side code
#   - middleware
#   - any code exposed to the browser
# Only use it in trusted server-side admin scripts if needed.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
